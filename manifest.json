{
  "manifest_version": 2,
  "name": "Quick Card Delete Button",
  "version": "2.8.0",
  "description": "Deletes messages directly via an icon in the message list.",
  "author": "sim32101",
  "permissions": [
    "messagesRead",
    "messagesMove",
    "storage"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false
  },
  "icons": {
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "experiment_apis": {
    "cardModifier": {
      "schema": "schema.json",
      "parent": {
        "scopes": [
          "addon_parent"
        ],
        "paths": [
          [
            "cardModifier"
          ]
        ],
        "script": "implementation.js"
      }
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-delete@your-domain.com",
      "strict_min_version": "140.0"
    }
  }
}